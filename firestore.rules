rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function hasAtLeastRole(role) {
      return isSignedIn() && (
        (role == 'staff' && userRole() in ['staff', 'manager', 'admin']) ||
        (role == 'manager' && userRole() in ['manager', 'admin']) ||
        (role == 'admin' && userRole() == 'admin')
      );
    }

    function isValidString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function userCreateValid() {
      return request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'photoUrl', 'emailVerified', 'createdAt', 'role'
        ])
        && isValidString(request.resource.data.name, 100)
        && isValidString(request.resource.data.email, 254)
        && request.resource.data.role == 'customer'
        && (!('phone' in request.resource.data)
            || request.resource.data.phone == null
            || isValidString(request.resource.data.phone, 20));
    }

    function userOwnerUpdateValid() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'phone', 'photoUrl', 'emailVerified', 'fcmToken', 'fcmTokenUpdatedAt'])
        && (!('name' in request.resource.data.diff(resource.data).affectedKeys())
            || isValidString(request.resource.data.name, 100))
        && (!('phone' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.phone == null
            || isValidString(request.resource.data.phone, 20))
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email;
    }

    function paymentIsSucceeded(paymentId) {
      let payment = get(/databases/$(database)/documents/payments/$(paymentId));
      return payment.data.userId == request.auth.uid
        && payment.data.status == 'succeeded';
    }

    function orderCreateValid() {
      return request.resource.data.keys().hasAll([
          'userId', 'totalAmount', 'status', 'createdAt', 'shippingAddress', 'items'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount > 0
        && request.resource.data.totalAmount <= 100000
        && isValidString(request.resource.data.shippingAddress, 300)
        && request.resource.data.status in ['Processing', 'Confirmed', 'Pending']
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && (
          !('paymentStatus' in request.resource.data)
          || (
            request.resource.data.paymentStatus == 'succeeded'
            && 'paymentId' in request.resource.data
            && paymentIsSucceeded(request.resource.data.paymentId)
          )
          || request.resource.data.paymentStatus in ['pending', 'processing', 'failed']
        );
    }

    function productWriteValid() {
      return request.resource.data.keys().hasOnly([
          'name', 'description', 'price', 'salePrice', 'images', 'categoryId',
          'inStock', 'stockQuantity', 'rating', 'reviewCount', 'featured', 'createdAt'
        ])
        && isValidString(request.resource.data.name, 200)
        && isValidString(request.resource.data.description, 2000)
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.price <= 100000
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() <= 40
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 10;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || hasAtLeastRole('admin');
      allow create: if isOwner(userId) && userCreateValid();
      allow update: if (isOwner(userId) && userOwnerUpdateValid())
        || (hasAtLeastRole('admin')
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']));
      allow delete: if hasAtLeastRole('admin');
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if hasAtLeastRole('manager') && productWriteValid();
      allow delete: if hasAtLeastRole('admin');
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        hasAtLeastRole('staff')
      );
      allow create: if isSignedIn() && orderCreateValid();
      allow update: if hasAtLeastRole('staff');
      allow delete: if hasAtLeastRole('admin');
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if hasAtLeastRole('staff');
      allow delete: if hasAtLeastRole('admin');
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }
  }
}
